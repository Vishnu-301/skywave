<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="page-hero page-hero--sm">
  <img src="https://images.unsplash.com/photo-1423946220476-5c7b97ca84e1?w=1400&auto=format&fit=crop" alt="Contact" class="page-hero-img" />
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <h1>Get in Touch</h1>
    <p>We're here to help 24 hours a day, 7 days a week</p>
  </div>
</section>

<section class="section">
  <div class="container contact-layout">

    <!-- Info Cards -->
    <div class="contact-info">
      <h2>Contact SkyWave</h2>
      <p>Have a question, need help with a booking, or want to give feedback? Reach out to our team and we'll respond promptly.</p>
      <div class="contact-cards">
        <div class="contact-card">
          <div class="contact-card-icon">📞</div>
          <div>
            <h4>Call Us</h4>
            <p>+234 800 SKYWAVE</p>
            <span>Mon–Sun, 24/7</span>
          </div>
        </div>
        <div class="contact-card">
          <div class="contact-card-icon">✉️</div>
          <div>
            <h4>Email Us</h4>
            <p>support@skywave.aero</p>
            <span>Response within 2 hours</span>
          </div>
        </div>
        <div class="contact-card">
          <div class="contact-card-icon">📍</div>
          <div>
            <h4>Visit Us</h4>
            <p>14 Aviation Way, Lagos</p>
            <span>Victoria Island, Nigeria</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="contact-form-wrap card">
      <% if (success) { %>
        <div class="alert alert-success">✅ <%= success %></div>
      <% } %>

      <form action="/contact" method="POST">
        <h3>Send a Message</h3>
        <div class="form-row">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="John Doe" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="john@example.com" required />
          </div>
        </div>
        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" placeholder="Booking enquiry, refund request..." />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Tell us how we can help..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Send Message ✈</button>
      </form>
    </div>

  </div>
</section>

<%- include('partials/footer') %>
