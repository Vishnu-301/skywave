# Local development — copy to .env and fill in your values
PORT=3000
NODE_ENV=development

# Local DB (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=skywave_db
DB_PORT=5432

# Production (Render sets this automatically via render.yaml)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
